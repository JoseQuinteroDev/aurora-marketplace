# Aurora Marketplace — environment template
#
# Copy to `.env` (which is gitignored) and adjust. docker-compose reads `.env`
# automatically. The values below are the LOCAL DEVELOPMENT DEFAULTS that ship in
# docker-compose.yml; override every one of them in any deployed environment.
#
#   cp .env.example .env        # macOS/Linux
#   Copy-Item .env.example .env # PowerShell
#
# SECURITY: never commit a real `.env`. Real secrets belong in a secret manager
# (e.g. cloud secrets, Vault), injected at deploy time — not in source control.
# The CI secret scanner (Gitleaks) will fail the build if credentials are committed.

# --- Spring profile ---
# Leave UNSET for local development (the default profile keeps the dev-friendly config below).
# In any DEPLOYED/production environment you MUST activate the 'prod' profile: it loads
# application-prod.yml (DB creds + JWT secret required with NO dev fallback) and arms
# JwtSecretValidator's fail-fast, so the app refuses to start on a known weak secret.
# For a host-run jar:  export SPRING_PROFILES_ACTIVE=prod   (for docker-compose, wire it into
# the backend service's `environment:` block — it is not auto-injected from this file).
# SPRING_PROFILES_ACTIVE=prod

# --- PostgreSQL ---
POSTGRES_DB=aurora_marketplace
POSTGRES_USER=aurora_user
POSTGRES_PASSWORD=aurora_password
# Backend datasource — defaults to the docker-compose Postgres above, but the app reads
# these directly (no committed credentials). Override all three in any deployed env.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/aurora_marketplace
SPRING_DATASOURCE_USERNAME=aurora_user
SPRING_DATASOURCE_PASSWORD=aurora_password

# --- MinIO (object storage) ---
MINIO_ROOT_USER=aurora_minio
MINIO_ROOT_PASSWORD=aurora_minio_password

# --- Application security (REQUIRED in production) ---
# Must be at least 32 characters. Generate a strong random value, e.g.:
#   PowerShell:  [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
#   bash:        openssl rand -base64 48
APP_SECURITY_JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
APP_SECURITY_JWT_EXPIRATION_MINUTES=60

# --- Gateway tuning (optional; defaults shown) ---
RATE_LIMIT_REPLENISH=20
RATE_LIMIT_BURST=40
GATEWAY_TIMEOUT=5s
